<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_scan_guide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="벽면에 스마트폰을 대고 천천히 스캔하세요"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.inhatc.smartwallsaver.scan.ScanGridView
        android:id="@+id/scan_grid_view"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:layout_marginTop="40dp"
        android:background="#1E1E1E"
        app:layout_constraintTop_toBottomOf="@id/tv_scan_guide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_scan_toggle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="탐지 시작"
        android:textColor="#000000"
        android:textStyle="bold"
        android:backgroundTint="#FF823A"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>